PORT=3001
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
REDIS_HOST=localhost
REDIS_PORT=6379
# Comma-separated allowed browser origins for HTTP CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
# Legacy single-origin fallback used when CORS_ORIGINS is not set
FRONTEND_URL=http://localhost:3000
# Cron for orphaned hold backstop (default: every minute)
# Demo: */10 * * * * *  (every 10s, 6-field cron) for fast seat release after tab close
RECONCILE_CRON_INTERVAL=
# Gemini API key for booking agent LLM calls
GOOGLE_GENERATIVE_AI_API_KEY=
# If true, holds are forced to 10s for demos
DEMO_FAST_HOLD=false
